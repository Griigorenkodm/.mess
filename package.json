{
  "name": "mess-local-messenger",
  "private": true,
  "version": "0.1.0",
  "description": "Local messenger (HTML/CSS/JS/TS) with themes, group chats, and message deletion.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json -w",
    "start": "node server/server.js",
    "start:local": "npm run build && node server/server.js",
    "start:pm2": "npx --yes pm2-runtime@5 start ecosystem.config.cjs",
    "dev": "node server/server.js",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "express": "^5.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
